  m_text: "\u0423\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435:\n\nWASD
    - \u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F \nQ - \u0437\u0430\u043B\u0430\u0437\u0438\u0442\u044C
